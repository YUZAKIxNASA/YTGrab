# Environment example for YTGrab backend

PORT=8000
NODE_ENV=production
YTDLP_PATH=yt-dlp
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
MAX_DOWNLOAD_MB=200
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
LOG_LEVEL=info
TEMP_DIR=/tmp/ytgrab
ANALYZE_CACHE_TTL_MS=600000
DOWNLOAD_TIMEOUT_MS=900000

